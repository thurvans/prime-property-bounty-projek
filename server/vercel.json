{
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run prisma:generate",
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "prisma/**",
        "src/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js?path=:path*"
    }
  ]
}
